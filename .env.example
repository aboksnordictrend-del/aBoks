# PostgreSQL connection string
# Local:   postgresql://user:password@localhost:5432/aboks
# Neon:    postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URI=postgresql://user:password@host:5432/dbname

# Generate a strong random string (min 32 chars)
PAYLOAD_SECRET=your-secret-key-minimum-32-characters-long

NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Zoho Mail (EU). Emails are disabled entirely unless all five are set.
SMTP_HOST=smtppro.zoho.eu
SMTP_PORT=465
SMTP_USER=post@aboks.no
SMTP_PASS=your-zoho-app-password
EMAIL_FROM=post@aboks.no
EMAIL_FROM_NAME=aBoks

# Optional email timeouts (ms). The defaults keep a stalled Zoho from ever holding a
# request open long enough to hit Vercel's FUNCTION_INVOCATION_TIMEOUT.
# SMTP_CONNECTION_TIMEOUT_MS=8000
# SMTP_GREETING_TIMEOUT_MS=6000
# SMTP_SOCKET_TIMEOUT_MS=10000
# EMAIL_SEND_TIMEOUT_MS=12000

# Set to 'true' to SMTP-verify the transport once per process (diagnostics only).
# SMTP_VERIFY=false

# --- Meta Marketing API (server-only; never expose to the browser) ---
# Used by the "Synkroniser fra Meta" action to import daily ad spend. The access token and
# app secret are secrets: keep them out of Git and never prefix any of these with
# NEXT_PUBLIC_. Set META_ACCESS_TOKEN / META_APP_SECRET in .env.local and in Vercel env vars.
META_APP_ID=1982122269089471
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_1171305661810272
META_GRAPH_API_VERSION=v24.0

# --- Google Ads API (server-only; never expose to the browser) ---
# Used by the Google Ads card under Markedsføringskanaler to import daily ad spend.
# GOOGLE_ADS_CLIENT_SECRET, GOOGLE_ADS_REFRESH_TOKEN and GOOGLE_ADS_DEVELOPER_TOKEN are
# secrets: keep them out of Git, never prefix any of these with NEXT_PUBLIC_, and set them in
# .env.local and in Vercel env vars only. They are never written to PostgreSQL.
#
#  CLIENT_ID / CLIENT_SECRET  — Google Cloud Console → APIs & Services → Credentials →
#                               OAuth 2.0 Client ID (type "Desktop app" or "Web application").
#  DEVELOPER_TOKEN            — Google Ads (manager account) → Tools → API Center.
#                               A token with *test* access cannot read a production account:
#                               apply for "Basic Access" there before the first sync.
#  REFRESH_TOKEN              — one-time OAuth consent for scope
#                               https://www.googleapis.com/auth/adwords, granted by a Google
#                               user that has access to the ad account. Added manually here.
#  CUSTOMER_ID                — the ad account the costs are read from (10 digits).
#  LOGIN_CUSTOMER_ID          — the manager account (MCC) above it. Optional: leave empty for
#                               a standalone account without a manager.
# Both ids may be written with or without dashes — they are normalized to digits internally.
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Optional. Only set these to override the defaults.
#  API_VERSION   — Google Ads API version segment (default v24). Bump it if Google sunsets
#                  the current one; the sync then reports a clear error asking for this.
#  HISTORY_START — floor for the one-off "when does this account's history start?" probe that
#                  a full import runs (default 2015-01-01).
# GOOGLE_ADS_API_VERSION=v24
# GOOGLE_ADS_HISTORY_START=2015-01-01
