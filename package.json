{
  "name": "aboks",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "payload generate:importmap && next build",
    "build:vercel": "payload generate:types && payload generate:importmap && node scripts/check-importmap.mjs && node scripts/check-migrations.mjs && payload migrate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "check:importmap": "node scripts/check-importmap.mjs",
    "check:migrations": "node scripts/check-migrations.mjs",
    "migrate": "payload migrate",
    "migrate:create": "payload migrate:create",
    "seed": "tsx src/seed.ts",
    "migrate:details": "tsx src/migrate-details.ts",
    "backfill:customers": "tsx src/backfill-customers.ts"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.85.1",
    "@payloadcms/email-nodemailer": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@payloadcms/storage-vercel-blob": "^3.85.1",
    "framer-motion": "^11.15.0",
    "graphql": "^16.9.0",
    "next": "^15.4.11",
    "nodemailer": "^9.0.1",
    "payload": "^3.85.1",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.33.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.20.2"
  }
}
